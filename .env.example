# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-key-here"

# Admin Credentials (değiştirin!)
ADMIN_EMAIL="admin@bursluluk.com"
ADMIN_PASSWORD="Admin123!@#"

# Application mode: yaz_okulu | bursluluk
NEXT_PUBLIC_APPLICATION_MODE="yaz_okulu"

# Okul yönetim sistemi (öğrenci listesi + webhook)
OKUL_YONETIM_API_URL="https://yonetim.leventokullari.com"
SERVICE_API_SECRET="shared-service-secret"
WEBHOOK_URL="https://yonetim.leventokullari.com/api/webhook/basvuru"
YAZ_OKULU_WEBHOOK_URL="https://yonetim.leventokullari.com/api/webhook/yaz-okulu-basvuru"
WEBHOOK_SECRET="shared-webhook-secret"

